@page "/"
@using AnalizadorSintacticoGo.Models
@using AnalizadorSintacticoGo.Services
@rendermode InteractiveServer
@using System.Text.RegularExpressions
@inject IJSRuntime JS 

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center rounded-top">
                    <h5 class="mb-0 font-monospace">📝 Editor Go</h5>
                    <button class="btn btn-success btn-sm fw-bold" @onclick="EjecutarAnalisis">
                        ▶ Ejecutar
                    </button>
                </div>
                <div class="card-body p-0 bg-editor">
                    <div class="d-flex editor-wrapper">

                        <div class="line-numbers text-end px-2 text-secondary font-monospace" id="lineNumbers">
                            @((MarkupString)NumerosDeLinea)
                        </div>

                        <div class="editor-container flex-grow-1">
                            <div class="highlight-layer font-monospace" aria-hidden="true">
                                @((MarkupString)CodigoConColores)
                            </div>
                            <textarea @bind="CodigoFuente"
                                      @bind:event="oninput"
                                      id="codigoEditor"
                                      class="form-control code-area transparent-text font-monospace"
                                      spellcheck="false"></textarea>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 d-flex flex-column gap-3">

            <div class="card shadow-sm border-0 flex-grow-1">
                <div class="card-header bg-black text-white border-bottom-0 rounded-top">
                    <h6 class="mb-0 font-monospace">>_ Terminal</h6>
                </div>
                <div class="card-body bg-black text-light font-monospace p-3 terminal-box">
                    @if (ListaErrores.Any())
                    {
                        <span class="text-danger">Existen errores de compilación. Revisa el reporte abajo.</span>
                    }
                    else if (ErroresEjecucion.Any())
                    {
                        @foreach (var err in ErroresEjecucion)
                        {
                            <div class="text-danger">@err</div>
                        }
                    }
                    else if (SalidaConsola.Any())
                    {
                        @foreach (var linea in SalidaConsola)
                        {
                            <div><span class="text-success">➜</span> @linea</div>
                        }
                    }
                    else if (AnalisisRealizado)
                    {
                        <span class="text-muted">Proceso terminado con código 0.</span>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 flex-grow-1">
                <div class="card-header bg-danger text-white rounded-top">
                    <h6 class="mb-0">🔍 Reporte de Compilación</h6>
                </div>
                <div class="card-body scrollable-table p-0">
                    @if (ListaErrores == null || !ListaErrores.Any())
                    {
                        @if (AnalisisRealizado)
                        {
                            <div class="p-4 text-center">
                                <h5 class="text-success">✅ ¡Compilación Exitosa!</h5>
                                <p class="text-muted mb-0">No se detectaron errores de sintaxis.</p>
                            </div>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <p class="mb-0">Esperando código para analizar...</p>
                            </div>
                        }
                    }
                    else
                    {
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Línea</th>
                                    <th>Mensaje</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var error in ListaErrores.OrderBy(e => e.Linea))
                                {
                                    <tr>
                                        <td class="text-center fw-bold text-danger">@error.Linea</td>
                                        <td><small>@error.Mensaje</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private string CodigoFuente = "package main\n\nfunc main() {\n    var mensaje = \"Hola Compilador\"\n    print mensaje\n}";
    private bool AnalisisRealizado = false;

    private List<Token> ListaTokens = new();
    private List<AnalisisError> ListaErrores = new();
    private List<string> SalidaConsola = new();
    private List<string> ErroresEjecucion = new();

    private string CodigoConColores => AplicarColores(CodigoFuente);

    private string NumerosDeLinea => GenerarNumerosLinea(CodigoFuente);

    private string GenerarNumerosLinea(string codigo)
    {
        if (string.IsNullOrEmpty(codigo)) return "1<br>";

        int cantidadLineas = codigo.Split('\n').Length;
        var sb = new System.Text.StringBuilder();

        for (int i = 1; i <= Math.Max(1, cantidadLineas); i++)
        {
            sb.Append($"{i}<br>");
        }
        return sb.ToString();
    }

    private string AplicarColores(string codigo)
    {
        if (string.IsNullOrEmpty(codigo)) return "";

        var html = codigo.Replace("<", "&lt;").Replace(">", "&gt;");

        html = Regex.Replace(html, @"&quot;.*?&quot;", m => $"<span style='color: #ce9178;'>{m.Value}</span>");

        html = Regex.Replace(html, @"\b\d+(\.\d+)?\b", m => $"<span style='color: #b5cea8;'>{m.Value}</span>");

        string[] keywords = { "func", "var", "if", "else", "for", "return", "package", "print", "true", "false" };
        foreach (var kw in keywords)
        {
            html = Regex.Replace(html, $@"\b{kw}\b", $"<span style='color: #569cd6; font-weight: bold;'>{kw}</span>");
        }

        html = Regex.Replace(html, @"//.*", m => $"<span style='color: #6a9955;'>{m.Value}</span>");

        return html;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("habilitarTabulador", "codigoEditor");
        }
    }

    private void EjecutarAnalisis()
    {
        AnalisisRealizado = true;
        ListaErrores.Clear(); ListaTokens.Clear(); SalidaConsola.Clear(); ErroresEjecucion.Clear();

        var scanner = new Escaner(CodigoFuente);
        ListaTokens = scanner.ScanTokens();
        ListaErrores.AddRange(scanner.Errores);

        if (ListaErrores.Any()) return;

        var parser = new Parser(ListaTokens);
        List<Instruccion> arbolSintactico = parser.Parse();
        ListaErrores.AddRange(parser.Errores);

        if (!ListaErrores.Any() && arbolSintactico != null && arbolSintactico.Any())
        {
            var evaluador = new Evaluador();
            evaluador.Ejecutar(arbolSintactico);
            SalidaConsola = evaluador.Consola;
            ErroresEjecucion = evaluador.ErroresEjecucion;
        }
    }
}